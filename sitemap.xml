---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url>
    <loc>{{ site.url }}{{ site.baseurl }}/</loc>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
    <priority>1.0</priority>
  </url>
  <url>
    <loc>{{ site.url }}{{ site.baseurl }}/archive</loc>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
    <priority>0.8</priority>
  </url>
  <url>
    <loc>{{ site.url }}{{ site.baseurl }}/about</loc>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
    <priority>0.7</priority>
  </url>
  <url>
    <loc>{{ site.url }}{{ site.baseurl }}/contact</loc>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
    <priority>0.7</priority>
  </url>
  {% for post in site.posts %}
  <url>
    <loc>{{ post.url | absolute_url }}</loc>
    <lastmod>{{ post.date | date_to_xmlschema }}</lastmod>
    <priority>0.6</priority>
  </url>
  {% endfor %}
  <url>
    <loc>{{ site.url }}{{ site.baseurl }}/category/tech</loc>
    <priority>0.5</priority>
  </url>
  <url>
    <loc>{{ site.url }}{{ site.baseurl }}/category/news</loc>
    <priority>0.5</priority>
  </url>
  <url>
    <loc>{{ site.url }}{{ site.baseurl }}/category/geopolitics</loc>
    <priority>0.5</priority>
  </url>
</urlset>
